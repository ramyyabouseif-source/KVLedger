# KVLedger Frontend Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================
# CONTRACT ADDRESSES
# ============================================

# Localhost Network (Hardhat)
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_OPTIMIZED_CONTRACT_ADDRESS=
NEXT_PUBLIC_SECURE_CONTRACT_ADDRESS=
NEXT_PUBLIC_ULTRA_OPTIMIZED_CONTRACT_ADDRESS=

# Sepolia Testnet
NEXT_PUBLIC_SEPOLIA_LOAN_REGISTRY=
NEXT_PUBLIC_SEPOLIA_OPTIMIZED=
NEXT_PUBLIC_SEPOLIA_SECURE=
NEXT_PUBLIC_SEPOLIA_ULTRA_OPTIMIZED=

# ============================================
# NETWORK CONFIGURATION
# ============================================

# RPC URLs
NEXT_PUBLIC_LOCALHOST_RPC_URL=http://localhost:8545
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application Environment
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_NAME=KVLedger
NEXT_PUBLIC_APP_VERSION=1.0.0

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ============================================
# SECURITY SETTINGS
# ============================================

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_WINDOW=60000
NEXT_PUBLIC_MAX_REQUESTS_PER_WINDOW=100

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT=86400000

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG_MODE=true
NEXT_PUBLIC_ENABLE_TEST_MODE=true

# ============================================
# EXTERNAL SERVICES
# ============================================

# Analytics (if enabled)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Debug Configuration
NEXT_PUBLIC_DEBUG_CONSOLE=true
NEXT_PUBLIC_DEBUG_NETWORK=false
NEXT_PUBLIC_DEBUG_CONTRACT=false

